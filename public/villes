<style>
:root {
  --bg: #030712;
  --bg2: #0f172a;
  --bg3: #1e293b;
  --text: #f1f5f9;
  --text2: #94a3b8;
  --accent: #00ffc3;
  --accent2: #22c55e;
  --grad: linear-gradient(135deg, #00ffc3, #22c55e);
  --grad2: linear-gradient(135deg, #3b82f6, #8b5cf6);
  --border: rgba(148,163,184,.1);
  --glow: 0 0 80px rgba(0,255,195,.08);
}
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }
body { font-family: 'Inter', -apple-system, sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; overflow-x: hidden; }

/* NAV */
nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 16px 32px; display: flex; align-items: center; justify-content: space-between; background: rgba(3,7,18,.8); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); }
.nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; color: var(--text); }
.nav-logo-icon { width: 36px; height: 36px; border-radius: 10px; background: var(--grad); display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 18px; color: #022c22; }
.nav-logo span { font-weight: 800; font-size: 18px; }
.nav-links { display: flex; gap: 24px; align-items: center; }
.nav-links a { color: var(--text); text-decoration: none; font-size: 14px; font-weight: 500; transition: color .2s; }
.nav-links a:hover { color: var(--accent); }
.nav-cta { padding: 8px 20px; background: var(--grad); color: #022c22; font-weight: 700; font-size: 13px; border-radius: 8px; text-decoration: none; transition: transform .15s, box-shadow .2s; box-shadow: 0 0 12px rgba(0,255,195,.3); }
.nav-cta:hover { transform: scale(1.03); box-shadow: 0 4px 20px rgba(0,255,195,.5); }

/* HERO */
.hero { padding: 140px 32px 80px; text-align: center; position: relative; }
.hero::before { content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 800px; height: 600px; background: radial-gradient(ellipse, rgba(0,255,195,.06) 0%, transparent 70%); pointer-events: none; }
.hero-badge { display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px; background: rgba(0,255,195,.08); border: 1px solid rgba(0,255,195,.15); border-radius: 24px; font-size: 12px; font-weight: 600; color: var(--accent); margin-bottom: 24px; }
.hero-badge .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); animation: pulse 2s infinite; }
.offer-note { display: inline-flex; align-items: center; gap: 8px; padding: 7px 14px; background: rgba(34,197,94,.1); border: 1px solid rgba(34,197,94,.28); border-radius: 999px; font-size: 12px; font-weight: 700; color: #86efac; margin-bottom: 18px; }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: .4; } }
.hero h1 { font-size: clamp(36px, 5vw, 64px); font-weight: 900; line-height: 1.1; margin-bottom: 20px; letter-spacing: -.02em; }
.hero h1 .grad-text { background: var(--grad); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { font-size: 18px; color: var(--text2); max-width: 640px; margin: 0 auto 36px; line-height: 1.7; }
.hero-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
.btn-primary { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; background: var(--grad); color: #022c22; font-weight: 700; font-size: 15px; border-radius: 12px; text-decoration: none; transition: transform .15s, box-shadow .2s; border: none; cursor: pointer; }
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,255,195,.25); }
.btn-secondary { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; background: var(--bg3); color: var(--text); font-weight: 600; font-size: 15px; border-radius: 12px; text-decoration: none; transition: all .2s; border: 1px solid var(--border); }
.btn-secondary:hover { border-color: rgba(0,255,195,.3); background: rgba(0,255,195,.05); }
.hero-stats { display: flex; gap: 48px; justify-content: center; margin-top: 60px; }
.stat { text-align: center; }
.stat-num { font-size: 32px; font-weight: 900; background: var(--grad); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.stat-label { font-size: 13px; color: var(--text2); margin-top: 4px; }

/* DEMO */
.demo { padding: 80px 32px; }
.section-label { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 700; color: var(--accent); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 12px; }
.section-title { font-size: clamp(28px, 3.5vw, 42px); font-weight: 800; margin-bottom: 16px; letter-spacing: -.01em; }
.section-desc { font-size: 16px; color: var(--text2); max-width: 560px; margin-bottom: 40px; }
.demo-container { max-width: 1100px; margin: 0 auto; }
.demo-controls { display: flex; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; align-items: center; }
.demo-controls label { font-size: 13px; color: var(--text2); font-weight: 500; }
.demo-select { padding: 8px 14px; background: var(--bg3); border: 1px solid var(--border); color: var(--text); border-radius: 8px; font-size: 13px; font-family: inherit; cursor: pointer; }
.demo-select:focus { outline: none; border-color: var(--accent); }
.demo-frame { border-radius: 16px; overflow: hidden; border: 1px solid var(--border); box-shadow: var(--glow); height: 520px; }
.demo-frame iframe { width: 100%; height: 100%; border: none; }

/* CODE */
.code-section { max-width: 1100px; margin: 40px auto 0; }
.code-header { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; background: var(--bg3); border-radius: 12px 12px 0 0; border: 1px solid var(--border); border-bottom: none; }
.code-header span { font-size: 12px; color: var(--text2); font-weight: 600; }
.code-copy { padding: 6px 14px; background: rgba(0,255,195,.1); color: var(--accent); border: 1px solid rgba(0,255,195,.2); border-radius: 6px; font-size: 11px; font-weight: 700; cursor: pointer; font-family: inherit; transition: all .2s; }
.code-copy:hover { background: rgba(0,255,195,.2); }
.code-block { padding: 20px; background: var(--bg2); border-radius: 0 0 12px 12px; border: 1px solid var(--border); border-top: none; overflow-x: auto; }
.code-block code { font-family: 'SF Mono', 'Fira Code', monospace; font-size: 13px; color: var(--text2); line-height: 1.6; white-space: pre; }
.code-block .tag { color: #f472b6; }
.code-block .attr { color: #60a5fa; }
.code-block .val { color: var(--accent); }

/* FEATURES */
.features { padding: 100px 32px; }
.features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; max-width: 1100px; margin: 0 auto; }
.feature-card { padding: 28px; background: var(--bg2); border-radius: 16px; border: 1px solid var(--border); transition: all .3s; }
.feature-card:hover { border-color: rgba(0,255,195,.2); transform: translateY(-2px); box-shadow: 0 8px 40px rgba(0,0,0,.3); }
.feature-icon { width: 44px; height: 44px; border-radius: 12px; background: rgba(0,255,195,.08); display: flex; align-items: center; justify-content: center; font-size: 20px; margin-bottom: 16px; }
.feature-card h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
.feature-card p { font-size: 14px; color: var(--text2); line-height: 1.6; }
.feature-free { display: inline-block; padding: 2px 8px; background: rgba(0,255,195,.1); color: var(--accent); font-size: 10px; font-weight: 700; border-radius: 4px; margin-left: 8px; text-transform: uppercase; }

/* HOW IT WORKS */
.how { padding: 100px 32px; background: var(--bg2); }
.how-inner { max-width: 900px; margin: 0 auto; }
.steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-top: 48px; }
.step { text-align: center; position: relative; }
.step-num { width: 56px; height: 56px; border-radius: 50%; background: var(--grad); display: flex; align-items: center; justify-content: center; font-size: 22px; font-weight: 900; color: #022c22; margin: 0 auto 20px; }
.step h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
.step p { font-size: 14px; color: var(--text2); }

/* API SECTION */
.api-section { padding: 100px 32px; }
.api-inner { max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
.api-text h2 { font-size: 32px; font-weight: 800; margin-bottom: 16px; }
.api-text p { font-size: 15px; color: var(--text2); margin-bottom: 20px; line-height: 1.7; }
.api-methods { display: flex; flex-direction: column; gap: 12px; }
.api-method { display: flex; align-items: center; gap: 12px; padding: 14px 18px; background: var(--bg2); border-radius: 12px; border: 1px solid var(--border); }
.api-method .icon { font-size: 20px; }
.api-method .method-text { flex: 1; }
.api-method h4 { font-size: 14px; font-weight: 600; }
.api-method p { font-size: 12px; color: var(--text2); }

/* CONTACT */
.contact { padding: 100px 32px; background: var(--bg2); }
.contact-inner { max-width: 640px; margin: 0 auto; text-align: center; }
.contact-inner h2 { font-size: 36px; font-weight: 800; margin-bottom: 12px; }
.contact-inner > p { font-size: 16px; color: var(--text2); margin-bottom: 40px; }
.contact-form { text-align: left; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
.form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
.form-group label { font-size: 13px; font-weight: 600; color: var(--text2); }
.form-group input, .form-group select, .form-group textarea { padding: 12px 14px; background: var(--bg); border: 1px solid var(--border); color: var(--text); border-radius: 10px; font-size: 14px; font-family: inherit; transition: border-color .2s; }
.form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: var(--accent); }
.form-group textarea { resize: vertical; min-height: 100px; }
.form-submit { width: 100%; padding: 14px; background: var(--grad); color: #022c22; font-weight: 700; font-size: 15px; border: none; border-radius: 10px; cursor: pointer; font-family: inherit; transition: transform .15s, box-shadow .2s; }
.form-submit:hover { transform: translateY(-1px); box-shadow: 0 6px 24px rgba(0,255,195,.3); }
.form-note { font-size: 12px; color: var(--text2); margin-top: 12px; text-align: center; }
#form-success { display: none; padding: 20px; background: rgba(0,255,195,.08); border: 1px solid rgba(0,255,195,.2); border-radius: 12px; text-align: center; margin-top: 20px; }
#form-success h3 { color: var(--accent); margin-bottom: 6px; }

/* FOOTER */
footer { padding: 40px 32px; border-top: 1px solid var(--border); text-align: center; }
footer p { font-size: 13px; color: var(--text2); }
footer a { color: var(--accent); text-decoration: none; }

/* RESPONSIVE */
@media (max-width: 768px) {
  nav { padding: 12px 16px; }
  .nav-links { display: none; }
  .hero { padding: 110px 20px 60px; }
  .hero-stats { gap: 24px; }
  .stat-num { font-size: 24px; }
  .features-grid { grid-template-columns: 1fr; }
  .steps { grid-template-columns: 1fr; gap: 24px; }
  .api-inner { grid-template-columns: 1fr; }
  .form-row { grid-template-columns: 1fr; }
  .demo-frame { height: 400px; }
}
</style>
</head>

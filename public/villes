          <h4>Flux RSS / iCal / Open Data</h4>
          <p>Si vous avez un flux existant (OpenAgenda, RSS, iCal), nous pouvons l'intégrer automatiquement. Contactez-nous !</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section class="contact" id="contact">
  <div class="contact-inner">
    <div class="section-label">&#128172; Parlons-en</div>
    <h2>Intéressé ? Contactez-nous</h2>
    <p>Remplissez ce formulaire et nous vous répondons sous 24h avec le widget personnalisé pour votre ville.</p>

    <form class="contact-form" id="contactForm">
      <div class="form-row">
        <div class="form-group">
          <label>Votre nom</label>
          <input type="text" id="formName" placeholder="Jean Dupont" required>
        </div>
        <div class="form-group">
          <label>Votre email</label>
          <input type="email" id="formEmail" placeholder="jean@maville.fr" required>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Ville / Organisation</label>
          <input type="text" id="formCity" placeholder="Mairie de Lyon" required>
        </div>
        <div class="form-group">
          <label>Votre rôle</label>
          <select id="formRole">
            <option value="">Sélectionnez...</option>
            <option value="communication">Service communication</option>
            <option value="culture">Service culture / événements</option>
            <option value="tourisme">Office de tourisme</option>
            <option value="webmaster">Webmaster / technique</option>
            <option value="elue">Élu(e) / direction</option>
            <option value="media">Média local</option>
            <option value="autre">Autre</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>Message (optionnel)</label>
        <textarea id="formMsg" placeholder="Dites-nous ce qui vous intéresse : intégration du widget, ajout d'événements, questions..."></textarea>
      </div>
      <button type="submit" class="form-submit">Envoyer ma demande &#8594;</button>
      <p class="form-note">Nous ne partageons jamais vos données. Réponse garantie sous 24h.</p>
    </form>

    <div id="form-success">
      <h3>&#10003; Message envoyé !</h3>
      <p>Merci pour votre intérêt. Nous vous répondons sous 24h à l'adresse indiquée.</p>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <p>&#169; 2026 <a href="https://mapevent.world">MapEvent</a> — La carte mondiale des événements, 100% open data, 100% gratuit.<br>Contact : <a href="mailto:mapeventworld@gmail.com">mapeventworld@gmail.com</a></p>
</footer>

<script>
var citySelect = document.getElementById('citySelect');
var themeSelect = document.getElementById('themeSelect');
var demoIframe = document.getElementById('demoIframe');
var embedCode = document.getElementById('embedCode');

function updateDemo() {
  var c = citySelect.value;
  var t = themeSelect.value;
  var frame = document.querySelector('.demo-frame');
  frame.innerHTML = '';
  var newUrl = 'widget-promo.html?city=' + encodeURIComponent(c) + '&theme=' + t + '&_r=' + Date.now();
  frame.innerHTML = '<iframe id="demoIframe" src="' + newUrl + '" style="width:100%;height:100%;border:none;"></iframe>';
  demoIframe = document.getElementById('demoIframe');

  var src = 'https://mapevent.world/widget-promo.html?city=' + encodeURIComponent(c) + '&theme=' + t;
  embedCode.innerHTML =
    '<span class="tag">&lt;iframe</span> <span class="attr">src</span>=<span class="val">"' + src + '"</span>\n' +
    '        <span class="attr">width</span>=<span class="val">"100%"</span> <span class="attr">height</span>=<span class="val">"520"</span> <span class="attr">frameborder</span>=<span class="val">"0"</span>\n' +
    '        <span class="attr">style</span>=<span class="val">"border-radius:16px; border:1px solid rgba(148,163,184,.1);"</span>\n' +
    '        <span class="attr">loading</span>=<span class="val">"lazy"</span><span class="tag">&gt;&lt;/iframe&gt;</span>';
}
citySelect.addEventListener('change', updateDemo);
themeSelect.addEventListener('change', updateDemo);

function copyCode() {
  var c = citySelect.value;
  var t = themeSelect.value;
  var raw = '<iframe src="https://mapevent.world/widget-promo.html?city=' + c + '&theme=' + t + '" width="100%" height="520" frameborder="0" style="border-radius:16px; border:1px solid rgba(148,163,184,.1);" loading="lazy"></iframe>';
  navigator.clipboard.writeText(raw).then(function() {
    var btn = document.getElementById('copyBtn');
    btn.textContent = 'Copié !';
    setTimeout(function() { btn.textContent = 'Copier le code'; }, 2000);
  });
}

document.getElementById('contactForm').addEventListener('submit', function(e) {
  e.preventDefault();
  var name = document.getElementById('formName').value;
  var email = document.getElementById('formEmail').value;
  var city = document.getElementById('formCity').value;
  var role = document.getElementById('formRole').value;
  var msg = document.getElementById('formMsg').value;

  var subject = encodeURIComponent('Widget MapEvent — ' + city);
  var body = encodeURIComponent(
    'Bonjour MapEvent,\n\n' +
    'Je suis intéressé(e) par le widget MapEvent pour notre ville/organisation.\n\n' +
    'Nom : ' + name + '\n' +
    'Email : ' + email + '\n' +
    'Ville / Organisation : ' + city + '\n' +
    'Rôle : ' + (role || 'Non précisé') + '\n\n' +
    'Message :\n' + (msg || '(Aucun message supplémentaire)') + '\n\n' +
    'Merci !'
  );

  window.location.href = 'mailto:mapeventworld@gmail.com?subject=' + subject + '&body=' + body;

  document.getElementById('contactForm').style.display = 'none';
  document.getElementById('form-success').style.display = 'block';
});
</script>
</body>
</html>
